{
  "permissions": {
    "allow": [
      "mcp__ide__getDiagnostics",
      "Bash(rustc --version)",
      "Bash(cargo --version)",
      "Bash(npm --version)",
      "Bash(npm install *)",
      "Bash(npx asc *)",
      "Bash(echo \"EXIT: $?\")",
