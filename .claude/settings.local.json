      "Bash(grep -rn \"^\\\\s*//.*console\\\\.\\\\|console\\\\.log\\\\|console\\\\.warn\\\\|console\\\\.error\" src/ --include=\"*.ts\" --include=\"*.svelte\")"
    ]
  }
}
